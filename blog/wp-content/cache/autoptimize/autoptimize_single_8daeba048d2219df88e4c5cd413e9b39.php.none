ive}.svc-stats-line{position:absolute;top:38%;left:0;width:100%;height:1px;background:linear-gradient(to right,transparent 0%,rgba(138,92,246,.55) 12%,rgba(138,92,246,.55) 88%,transparent 100%);transform:translateY(-50%) scaleX(0);transform-origin:left center;pointer-events:none;z-index:0}.svc-stat{position:relative;z-index:1}.svc-stat-mark{width:36px !important;height:36px !important}.svc-stat-number{font-size:clamp(4.5rem, 8vw, 8rem) !important;line-height:.92 !important;letter-spacing:-.05em !important}.svc-problem-gaps{list-style:none;margin:1.5rem 0 2rem;padding:0;border-left:2px solid rgba(84,61,152,.4);padding-left:1.5rem}.svc-problem-gaps li{display:flex;align-items:center;gap:1rem;padding:.75rem 0;color:var(--soft-grey);opacity:0;transform:translateX(-14px);font-size:1.05rem;line-height:1.45;position:relative}.svc-problem-gaps .gap-mark{width:14px;height:14px;flex-shrink:0;opacity:.6}.svc-problem-gaps .gap-mark svg{width:100%;height:100%;fill:var(--impulse-violet)}.svc-problem-gaps .gap-text{position:relative;display:inline-block}.svc-problem-gaps .gap-text:after{display:none}.svc-systems-grid{align-items:center !important}.svc-systems-stage{position:relative;width:100%;aspect-ratio:1/1;max-width:560px;margin-left:auto}.svc-systems-stage .lines{position:absolute;inset:0;width:100%;height:100%;pointer-events:none}.svc-systems-stage .lines line{stroke:rgba(138,92,246,.22);stroke-width:1;stroke-dasharray:3 6}.svc-systems-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:150px;height:150px;pointer-events:none;animation:mark-breathe 6s ease-in-out infinite}.svc-systems-center svg{width:100%;height:100%;display:block}.svc-systems-center path{fill:none;stroke:rgba(138,92,246,.85);stroke-width:6}.svc-system-node{position:absolute;transform:translate(-50%,-50%);background:rgba(2,0,24,.88);border:1px solid rgba(138,92,246,.4);border-radius:14px;padding:.85rem 1.1rem;font-family:var(--font-body);font-size:.72rem;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:var(--soft-grey);backdrop-filter:blur(8px);text-align:center;max-width:220px;line-height:1.4;transition:all .3s ease;cursor:default}.svc-system-node:hover{border-color:var(--impulse-violet);color:var(--white);box-shadow:0 0 28px rgba(138,92,246,.4)}.svc-systems-pulse{fill:rgba(168,130,255,1)}.svc-guard-punchline{display:flex !important;flex-direction:column;align-items:center;justify-content:center;font-size:clamp(3rem, 7.5vw, 7.5rem) !important;margin:2rem 0 0 !important;padding:2rem 0 !important;text-align:center !important;line-height:1.02 !important;letter-spacing:-.04em !important;font-weight:800 !important;position:relative}.svc-guard-punchline-line{display:block;overflow:hidden;padding-bottom:.28em;margin-bottom:-.18em;line-height:1.1}.svc-guard-punchline-line .inner{display:inline-block}.svc-final-cta{padding:14rem 0 13rem !important;position:relative;overflow:hidden;text-align:center}.svc-final-cta-mark{position:absolute !important;top:50% !important;left:50% !important;transform:translate(-50%,-50%) !important;width:min(85vw, 1100px) !important;height:min(85vw, 1100px) !important;margin:0 !important;opacity:1 !important;z-index:0 !important;pointer-events:none}.svc-final-cta-mark svg{width:100%;height:100%}.svc-final-cta-mark path{stroke:rgba(138,92,246,.1);stroke-width:1.6}.svc-final-cta .container{isolation:isolate}.svc-systems-pills{display:flex;flex-direction:column;gap:.85rem;margin-top:.5rem}.svc-system-pill{padding:.75rem 1.6rem;border:1px solid rgba(138,92,246,.3);border-radius:100px;font-family:var(--font-body);font-size:.82rem;font-weight:500;color:var(--soft-grey);letter-spacing:1.5px;text-transform:uppercase;text-align:center;line-height:1.4;transition:border-color .3s ease,color .3s ease}.svc-system-pill:hover{border-color:var(--impulse-violet);color:var(--white)}.svc-final-cta .container{position:relative;z-index:2}.svc-final-cta h2{font-size:clamp(3rem, 8.5vw, 8.5rem) !important;line-height:.98 !impor