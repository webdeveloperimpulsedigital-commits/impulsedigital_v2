gress, 0) * 100%)) 0 0 0);transition:clip-path .3s cubic-bezier(.23,1,.32,1),fill .4s ease}.scroll-to-top:hover .scroll-boomerang .boomerang-fill{fill:var(--white)}@media (max-width:768px){.scroll-to-top{bottom:1.5rem;right:1.5rem;width:50px;height:50px}}.cs3-page{color:var(--white);min-height:100vh;background:0 0}.cs3-hero{padding:12rem 2rem 6rem;max-width:1600px;margin:0 auto}.cs3-hero-title{font-size:clamp(3.5rem, 8vw, 8rem);font-weight:400;line-height:1;letter-spacing:-.04em;margin-bottom:3rem;font-family:var(--font-heading)}.cs3-hero-title .line-wrapper{overflow:hidden;padding-bottom:.1em}.cs3-hero-desc{max-width:600px;font-size:clamp(1.1rem, 1.5vw, 1.5rem);line-height:1.5;color:rgba(255,255,255,.6);font-weight:300}.cs3-grid-wrapper{width:100%}.cs3-grid{display:grid;grid-template-columns:repeat(2,1fr);width:100%}.cs3-grid-item{position:relative;aspect-ratio:1/1;display:flex;flex-direction:column;justify-content:space-between;padding:4rem;cursor:pointer;overflow:hidden;border-top:1px solid rgba(255,255,255,.1)}.cs3-grid-item:nth-child(odd){border-right:1px solid rgba(255,255,255,.1)}.cs3-grid-item.theme-dark{background-color:transparent;color:var(--white)}.cs3-grid-item.theme-light{background-color:#efefef;color:var(--core-black)}.cs3-item-header{z-index:2}.cs3-client{font-family:var(--font-heading);font-size:clamp(2rem, 3vw, 3.5rem);font-weight:400;letter-spacing:-.02em;margin-bottom:1.5rem;text-transform:uppercase}.cs3-desc{font-size:clamp(1rem, 1.2vw, 1.2rem);line-height:1.5;max-width:400px;opacity:.7;font-weight:300}.cs3-media-container{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;z-index:1}.cs3-media-wrapper{position:relative;width:50%;height:50%;display:flex;align-items:center;justify-content:center}.cs3-hover-media{max-width:100%;max-height:100%;object-fit:contain;will-change:transform}.cs3-play-indicator{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(.8);width:80px;height:80